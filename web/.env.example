NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Filled in automatically by scripts/deploy-testnet.sh
NEXT_PUBLIC_OLIO_REGISTRY_ID=
NEXT_PUBLIC_OLIO_POOL_ID=
NEXT_PUBLIC_USDC_SAC_ID=
NEXT_PUBLIC_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Must match the pool's Merkle depth passed to initialize (deploy default: 20)
NEXT_PUBLIC_POOL_DEPTH=20
# Uploaded passkey smart-wallet WASM hash (from deploy-testnet.sh). Clients deploy
# a per-user smart-wallet contract instance from this hash — no factory.
NEXT_PUBLIC_SMART_WALLET_WASM_HASH=

# --- MongoDB (off-chain mirror: deposits/withdrawals/usernames cache) ---
# Server-only — never add a NEXT_PUBLIC_ prefix.
MONGODB_URI=mongodb://localhost:27017/olio

# --- OpenZeppelin Channels relayer (gasless Soroban writes) ---
# Sponsors every passkey smart-wallet deploy/register/deposit/withdraw so users
# need no XLM. The API key is SERVER-ONLY (no NEXT_PUBLIC_ prefix). Generate a
# testnet key at https://channels.openzeppelin.com/testnet/gen
CHANNELS_API_KEY=
# Managed service URL; mainnet is https://channels.openzeppelin.com
CHANNELS_BASE_URL=https://channels.openzeppelin.com/testnet